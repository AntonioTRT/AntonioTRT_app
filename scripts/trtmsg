#!/bin/bash
#
# Script principal para ejecutar comandos de trtmsg.
# Se encarga de activar el entorno virtual y llamar al script de Python.
#

# Navegar a la raíz del proyecto desde la ubicación de este script
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" &>/dev/null && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$PROJECT_ROOT"

# Activar el entorno virtual. Si no existe, el setup debería haberlo creado.
if [ -f ".venv/bin/activate" ]; then
    source .venv/bin/activate
else
    echo "Error: Entorno virtual no encontrado en $(pwd)/.venv" >&2
    echo "Por favor, ejecuta el script setup.sh primero." >&2
    exit 1
fi

# Ejecutar el script de Python, pasando todos los argumentos
python core/trtmsg.py "$@"